rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Owner can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Any authenticated user (including anonymous) can read for verification
      allow read: if request.auth != null;
    }

    // Staff config — readable by authenticated users (including anonymous) for PIN verification
    match /config/staff {
      allow read: if request.auth != null;
      allow write: if false; // Update manually via Firebase Console
    }
  }
}
